# AI Memory OS — environment override template
# Copy to .env (already gitignored) and edit. All keys are optional; compose falls back
# to the historical default values if unset, so existing deployments keep working.

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=memoryos
POSTGRES_PASSWORD=memoryos
POSTGRES_DB=memory_os

# --- Neo4j --------------------------------------------------------------------
NEO4J_PASSWORD=password

# --- MinIO --------------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# --- Grafana (only used with docker-compose.prod.yml) -------------------------
GRAFANA_PASSWORD=admin

# --- AI Memory OS app secrets ------------------------------------------------
# Base64-encoded 32 random bytes. When set, provider API keys are encrypted at rest
# with AES-256-GCM. When unset, keys are stored in plaintext and a startup WARNING
# is logged. Generate with:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
MEMORY_OS_MASTER_KEY=

# ── SMTP for email verification ──
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_qq_authorization_code
SMTP_FROM=Cortex <your_email@qq.com>
