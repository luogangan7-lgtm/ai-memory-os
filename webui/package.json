    "framer-motion": "^11.5.0",
    "gsap": "^3.12.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.15.0",
    "three": "^0.168.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.168.0",
